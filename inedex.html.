<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INEDEP · Institución Educativa para la Educación, Diversidad y Progreso</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Lexend:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#1A1464;
    --red:#E8483C;
    --green:#6FBE44;
    --blue:#2E8FD6;
    --purple:#9B4F9E;
    --orange:#F5A937;
    --yellow:#F6D94E;
    --leaf:#2E9C5C;
    --cream:#FFFBF1;
    --ink:#23214A;
    --card:#ffffff;
    --radius:22px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    font-family:'Lexend', sans-serif;
    background:var(--cream);
    color:var(--ink);
    line-height:1.6;
    font-size:17px;
  }
  h1,h2,h3,h4{
    font-family:'Baloo 2', sans-serif;
    color:var(--navy);
    margin:0 0 .3em 0;
    letter-spacing:.2px;
  }
  p{margin:.4em 0;}
  a{color:inherit;}
  img{max-width:100%;display:block;}
  .wrap{max-width:1100px;margin:0 auto;padding:0 22px;}

  /* ===== NAV ===== */
  nav{
    position:sticky; top:0; z-index:50;
    background:var(--navy);
    box-shadow:0 3px 14px rgba(0,0,0,.18);
  }
  .navbar{
    max-width:1100px;margin:0 auto;padding:10px 22px;
    display:flex;align-items:center;gap:14px;flex-wrap:wrap;
    justify-content:space-between;
  }
  .brand{display:flex;align-items:center;gap:10px;color:#fff;font-family:'Baloo 2';font-weight:800;font-size:1.15rem;}
  .brand img{width:42px;height:42px;object-fit:contain;border-radius:8px;background:#fff;padding:2px;}
  .navlinks{display:flex;gap:6px;flex-wrap:wrap;}
  .navlinks a{
    text-decoration:none;color:#fff;font-weight:600;font-size:.92rem;
    padding:8px 12px;border-radius:999px;transition:.2s;
    border:2px solid transparent;
  }
  .navlinks a:hover, .navlinks a:focus-visible{background:rgba(255,255,255,.14); border-color:rgba(255,255,255,.4);}

  /* ===== HERO ===== */
  .hero{
    background:
      radial-gradient(circle at 15% 20%, rgba(232,72,60,.16), transparent 40%),
      radial-gradient(circle at 85% 15%, rgba(46,143,214,.16), transparent 40%),
      radial-gradient(circle at 50% 90%, rgba(111,190,68,.14), transparent 45%),
      var(--cream);
    padding:52px 0 34px;
    text-align:center;
    border-bottom:6px solid var(--yellow);
  }
  .hero img.shield{
    width:230px;margin:0 auto 18px;
    filter:drop-shadow(0 10px 18px rgba(26,20,100,.25));
  }
  .hero h1{font-size:2.5rem;margin-bottom:.15em;}
  .hero .sub{
    font-size:1.15rem;font-weight:600;color:var(--navy);opacity:.85;
    max-width:640px;margin:0 auto;
  }
  .rainbow-strip{
    display:flex;justify-content:center;gap:8px;margin-top:22px;flex-wrap:wrap;
  }
  .rainbow-strip span{
    width:34px;height:12px;border-radius:8px;
  }

  /* ===== SECTION SHELL ===== */
  section{padding:56px 0;}
  .section-title{
    display:flex;align-items:center;gap:14px;margin-bottom:8px;
  }
  .section-title .tag{
    font-size:.78rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;
    color:#fff;padding:5px 12px;border-radius:999px;
  }
  .section-title h2{font-size:1.9rem;margin:0;}
  .section-intro{max-width:720px;color:var(--ink);opacity:.85;margin-bottom:28px;}

  /* ===== MISIÓN / VISIÓN ===== */
  .mv-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
  @media(max-width:720px){.mv-grid{grid-template-columns:1fr;}}
  .mv-card{
    background:var(--card);border-radius:var(--radius);padding:28px 26px;
    box-shadow:0 8px 24px rgba(26,20,100,.08);
    border-top:8px solid var(--blue);
  }
  .mv-card.vision{border-top-color:var(--purple);}
  .mv-card .icon{font-size:2.1rem;margin-bottom:6px;}

  /* ===== VALORES (hands) ===== */
  .values-grid{
    display:grid;grid-template-columns:repeat(5,1fr);gap:14px;
  }
  @media(max-width:900px){.values-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:480px){.values-grid{grid-template-columns:1fr;}}
  .value-card{
    background:#fff;border-radius:18px;padding:18px 12px;text-align:center;
    box-shadow:0 6px 16px rgba(26,20,100,.08);
    border-bottom:6px solid var(--v-color, var(--navy));
  }
  .value-card .emoji{font-size:2.3rem;}
  .value-card h4{font-size:.98rem;margin:.3em 0 .15em;}
  .value-card p{font-size:.83rem;opacity:.8;margin:0;}

  /* ===== UNIDAD 1 HEADER BANNER ===== */
  .unit-banner{
    background:linear-gradient(120deg, var(--green), var(--leaf));
    border-radius:28px;padding:34px 30px;color:#fff;
    display:flex;align-items:center;gap:20px;flex-wrap:wrap;
    box-shadow:0 10px 26px rgba(46,156,92,.28);
  }
  .unit-banner .big-emoji{font-size:3.4rem;}
  .unit-banner h2{color:#fff;font-size:1.7rem;margin-bottom:.1em;}
  .unit-banner p{margin:0;opacity:.95;font-weight:500;}
  .pill-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;}
  .pill{background:rgba(255,255,255,.22);padding:6px 13px;border-radius:999px;font-size:.82rem;font-weight:600;}

  /* ===== OBJETIVOS ===== */
  .obj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:26px;}
  @media(max-width:800px){.obj-grid{grid-template-columns:1fr 1fr;}}
  @media(max-width:520px){.obj-grid{grid-template-columns:1fr;}}
  .obj-card{
    background:#fff;border-radius:18px;padding:18px;
    box-shadow:0 6px 16px rgba(26,20,100,.07);
    border-left:6px solid var(--orange);
  }
  .obj-card .num{
    display:inline-flex;align-items:center;justify-content:center;
    width:30px;height:30px;border-radius:50%;background:var(--orange);color:#fff;
    font-family:'Baloo 2';font-weight:700;font-size:.9rem;margin-bottom:8px;
  }
  .obj-card p{font-size:.92rem;margin:0;}

  /* ===== CONTENIDO tabs ===== */
  .content-tabs{display:flex;gap:10px;flex-wrap:wrap;margin:26px 0 18px;}
  .ctab{
    cursor:pointer;background:#fff;border:2px solid var(--navy);color:var(--navy);
    padding:10px 16px;border-radius:999px;font-weight:700;font-size:.9rem;
    font-family:'Baloo 2';transition:.2s;
  }
  .ctab.active, .ctab:hover{background:var(--navy);color:#fff;}
  .content-panel{display:none;}
  .content-panel.active{display:block;}
  .info-card{
    background:#fff;border-radius:var(--radius);padding:26px;
    box-shadow:0 8px 22px rgba(26,20,100,.08);
  }
  .info-flex{display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start;}
  .info-visual{
    flex:0 0 190px;background:var(--yellow);border-radius:18px;
    display:flex;align-items:center;justify-content:center;font-size:4.4rem;
    height:190px;
  }
  .info-text{flex:1;min-width:240px;}
  .info-text h3{font-size:1.25rem;}
  .badge-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;}
  .badge{
    display:flex;align-items:center;gap:8px;background:var(--cream);
    padding:8px 12px;border-radius:14px;font-size:.85rem;font-weight:600;
    border:2px solid #eee;
  }
  .badge .dot{width:12px;height:12px;border-radius:50%;}

  /* ===== ESTRATEGIAS ===== */
  .strat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:24px;}
  @media(max-width:700px){.strat-grid{grid-template-columns:1fr;}}
  .strat-card{
    background:#fff;border-radius:18px;padding:18px;display:flex;gap:14px;align-items:flex-start;
    box-shadow:0 6px 16px rgba(26,20,100,.07);
  }
  .strat-card .se{font-size:1.6rem;flex:0 0 auto;}
  .strat-card h4{margin:0 0 4px;font-size:1rem;}
  .strat-card p{margin:0;font-size:.88rem;opacity:.85;}
  .callout{
    margin-top:22px;background:var(--purple);color:#fff;border-radius:18px;
    padding:18px 22px;font-size:.92rem;font-weight:500;
  }
  .callout b{font-family:'Baloo 2';}

  /* ===== ACTIVIDADES ===== */
  .activity-card{
    background:#fff;border-radius:var(--radius);padding:26px;margin-bottom:26px;
    box-shadow:0 8px 22px rgba(26,20,100,.08);
  }
  .activity-head{display:flex;align-items:center;gap:12px;margin-bottom:6px;}
  .activity-head .aemoji{font-size:1.8rem;}
  .activity-instructions{
    background:var(--cream);border-radius:14px;padding:10px 16px;font-size:.88rem;
    display:inline-flex;align-items:center;gap:8px;margin:8px 0 20px;font-weight:600;
  }
  .game-area{display:flex;gap:26px;flex-wrap:wrap;}
  .cards-pool{
    display:flex;flex-wrap:wrap;gap:12px;flex:1;min-width:260px;
  }
  .draggable{
    background:var(--cream);border:2px solid #e2ddc9;border-radius:16px;
    padding:12px 14px;font-size:1.6rem;cursor:pointer;text-align:center;
    min-width:74px;transition:.15s;user-select:none;position:relative;
  }
  .draggable .label{display:block;font-size:.68rem;font-family:'Lexend';font-weight:600;margin-top:4px;color:var(--ink);}
  .draggable.selected{border-color:var(--navy);background:#fff;box-shadow:0 0 0 3px rgba(26,20,100,.15);}
  .draggable.placed{opacity:0;pointer-events:none;}
  .buckets{display:flex;gap:14px;flex:1;min-width:260px;flex-wrap:wrap;}
  .bucket{
    flex:1;min-width:140px;border-radius:16px;padding:14px;min-height:150px;
    border:3px dashed var(--b-color, var(--navy));text-align:center;
    display:flex;flex-direction:column;gap:8px;background:rgba(0,0,0,.015);
  }
  .bucket h5{margin:0 0 4px;font-family:'Baloo 2';color:var(--b-color,var(--navy));font-size:.95rem;}
  .bucket .placed-item{
    background:#fff;border-radius:10px;padding:6px;font-size:1.3rem;
    box-shadow:0 2px 6px rgba(0,0,0,.08);
  }
  .bucket.correct-flash{background:rgba(111,190,68,.18);}
  .bucket.wrong-flash{background:rgba(232,72,60,.18);}
  .reset-btn, .check-btn{
    font-family:'Baloo 2';font-weight:700;border:none;border-radius:999px;
    padding:10px 20px;cursor:pointer;font-size:.9rem;margin-top:16px;margin-right:8px;
    transition:.2s;
  }
  .reset-btn{background:#eee;color:var(--ink);}
  .reset-btn:hover{background:#ddd;}
  .check-btn{background:var(--green);color:#fff;}
  .check-btn:hover{background:var(--leaf);}
  .feedback-msg{margin-top:14px;font-weight:700;font-family:'Baloo 2';font-size:.98rem;min-height:1.4em;}

  /* ===== QUIZ ===== */
  .quiz-q{margin-bottom:26px;}
  .quiz-q p.qtext{font-weight:700;font-size:1.02rem;color:var(--navy);}
  .quiz-opts{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  @media(max-width:600px){.quiz-opts{grid-template-columns:1fr;}}
  .opt-btn{
    text-align:left;background:var(--cream);border:2px solid #e6e0cd;border-radius:14px;
    padding:12px 16px;font-family:'Lexend';font-size:.92rem;cursor:pointer;transition:.15s;
  }
  .opt-btn:hover{border-color:var(--blue);}
  .opt-btn.correct{background:rgba(111,190,68,.25);border-color:var(--green);}
  .opt-btn.wrong{background:rgba(232,72,60,.2);border-color:var(--red);}
  .opt-btn[disabled]{cursor:default;}
  .quiz-explain{font-size:.85rem;margin-top:6px;opacity:.85;display:none;}
  .quiz-score{
    background:var(--navy);color:#fff;border-radius:16px;padding:16px 20px;
    font-family:'Baloo 2';font-size:1.1rem;text-align:center;margin-top:10px;
  }

  footer{
    background:var(--navy);color:#fff;text-align:center;padding:26px 20px;font-size:.85rem;
  }
  footer b{font-family:'Baloo 2';}
  .skip-link{position:absolute;left:-999px;}
  .skip-link:focus{left:10px;top:10px;background:#fff;color:var(--navy);padding:8px 14px;border-radius:8px;z-index:200;}
</style>
</head>
<body>
<a class="skip-link" href="#main">Saltar al contenido</a>

<nav>
  <div class="navbar">
    <div class="brand"><img src="escudo-inedep.jpg" alt="Escudo INEDEP"> INEDEP</div>
    <div class="navlinks">
      <a href="#inicio">Inicio</a>
      <a href="#nosotros">Misión y Visión</a>
      <a href="#valores">Valores</a>
      <a href="#unidad1">Unidad 1 · Biología</a>
      <a href="#actividades">Actividades</a>
      <a href="#quiz">Quiz</a>
    </div>
  </div>
</nav>

<header class="hero" id="inicio">
  <div class="wrap">
    <img class="shield" src="escudo-inedep.jpg" alt="Escudo de la Institución Educativa INEDEP">
    <h1>INEDEP</h1>
    <p class="sub">Institución Educativa para la Educación, Diversidad y Progreso</p>
    <div class="rainbow-strip">
      <span style="background:var(--red)"></span>
      <span style="background:var(--green)"></span>
      <span style="background:var(--blue)"></span>
      <span style="background:var(--purple)"></span>
      <span style="background:var(--orange)"></span>
    </div>
  </div>
</header>

<main id="main">

  <!-- ===== NOSOTROS ===== -->
  <section id="nosotros">
    <div class="wrap">
      <div class="section-title">
        <span class="tag" style="background:var(--blue)">Nosotros</span>
        <h2>Misión y Visión</h2>
      </div>
      <p class="section-intro">Lo que nos mueve cada día y hacia dónde vamos como comunidad educativa.</p>
      <div class="mv-grid">
        <div class="mv-card">
          <div class="icon">🎯</div>
          <h3>Misión</h3>
          <p>En INEDEP formamos estudiantes felices y capaces, respetando el ritmo y la forma de aprender de cada uno. Enseñamos con creatividad, usamos imágenes, juegos y actividades prácticas para que todos —con o sin dificultades de aprendizaje— entiendan, participen y disfruten aprender.</p>
        </div>
        <div class="mv-card vision">
          <div class="icon">🌱</div>
          <h3>Visión</h3>
          <p>Ser una institución reconocida por su educación inclusiva y diversa, donde la diferencia se celebra como una fortaleza, y donde cada estudiante avanza hacia el progreso con las herramientas, el apoyo y la confianza que necesita.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALORES ===== -->
  <section id="valores" style="background:#fff;">
    <div class="wrap">
      <div class="section-title">
        <span class="tag" style="background:var(--purple)">Nuestro escudo</span>
        <h2>Cinco manos, un mismo propósito</h2>
      </div>
      <p class="section-intro">Cada mano de nuestro escudo representa un compromiso con la diversidad y la inclusión.</p>
      <div class="values-grid">
        <div class="value-card" style="--v-color:var(--red)"><div class="emoji">👁️</div><h4>Discapacidad visual</h4><p>Apoyo y accesibilidad para aprender sin barreras.</p></div>
        <div class="value-card" style="--v-color:var(--green)"><div class="emoji">🎵</div><h4>Comunicación</h4><p>Distintas formas de expresarse y comunicarse.</p></div>
        <div class="value-card" style="--v-color:var(--blue)"><div class="emoji">♿</div><h4>Discapacidad física</h4><p>Espacios y actividades accesibles para todos.</p></div>
        <div class="value-card" style="--v-color:var(--purple)"><div class="emoji">🧠</div><h4>Neurodiversidad</h4><p>Distintas maneras de pensar y aprender.</p></div>
        <div class="value-card" style="--v-color:var(--orange)"><div class="emoji">⚖️</div><h4>Igualdad</h4><p>Las mismas oportunidades para cada estudiante.</p></div>
      </div>
    </div>
  </section>

  <!-- ===== UNIDAD 1 ===== -->
  <section id="unidad1">
    <div class="wrap">
      <div class="unit-banner">
        <div class="big-emoji">🐣🌻</div>
        <div>
          <h2>Unidad 1: ¡La vida se multiplica!</h2>
          <p>Biología · Reproducción en animales y plantas</p>
          <div class="pill-row">
            <span class="pill">🎯 Objetivos</span>
            <span class="pill">📚 Contenido</span>
            <span class="pill">🧩 Estrategias</span>
            <span class="pill">🎮 Actividades</span>
          </div>
        </div>
      </div>

      <!-- Objetivos -->
      <h3 style="margin-top:38px;">🎯 Objetivos de la unidad</h3>
      <div class="obj-grid">
        <div class="obj-card"><span class="num">1</span><p>Diferenciar la reproducción <b>sexual</b> y <b>asexual</b> en los seres vivos.</p></div>
        <div class="obj-card"><span class="num">2</span><p>Reconocer animales <b>ovíparos, vivíparos y ovovivíparos</b> con ejemplos reales.</p></div>
        <div class="obj-card"><span class="num">3</span><p>Identificar formas de reproducción en plantas: <b>semillas, esporas y vegetativa</b>.</p></div>
        <div class="obj-card"><span class="num">4</span><p>Valorar la reproducción como clave para la <b>continuidad de las especies</b>.</p></div>
        <div class="obj-card"><span class="num">5</span><p>Clasificar ejemplos mediante <b>actividades prácticas</b>, sin depender solo de la escritura.</p></div>
      </div>

      <!-- Contenido -->
      <h3 style="margin-top:44px;">📚 Contenido</h3>
      <div class="content-tabs">
        <div class="ctab active" data-tab="c1">🌍 ¿Qué es reproducirse?</div>
        <div class="ctab" data-tab="c2">🐾 Animales</div>
        <div class="ctab" data-tab="c3">🌿 Plantas</div>
      </div>

      <div class="content-panel active" id="c1">
        <div class="info-card">
          <div class="info-flex">
            <div class="info-visual">🌍</div>
            <div class="info-text">
              <h3>Reproducirse es crear vida nueva</h3>
              <p>Es el proceso por el cual los seres vivos originan nuevos individuos parecidos a ellos, para que la especie continúe existiendo.</p>
              <div class="badge-row">
                <div class="badge"><span class="dot" style="background:var(--orange)"></span>Asexual: un solo padre, copias idénticas</div>
                <div class="badge"><span class="dot" style="background:var(--blue)"></span>Sexual: dos padres, mayor diversidad</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="content-panel" id="c2">
        <div class="info-card">
          <div class="info-flex">
            <div class="info-visual">🐣</div>
            <div class="info-text">
              <h3>Reproducción en animales</h3>
              <p>Los animales se agrupan según cómo nacen sus crías:</p>
              <div class="badge-row">
                <div class="badge"><span class="dot" style="background:var(--red)"></span>🥚 Ovíparos: nacen de huevos (aves, peces)</div>
                <div class="badge"><span class="dot" style="background:var(--green)"></span>🐶 Vivíparos: nacen del vientre materno (mamíferos)</div>
                <div class="badge"><span class="dot" style="background:var(--purple)"></span>🐍 Ovovivíparos: el huevo se desarrolla dentro y nace vivo</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="content-panel" id="c3">
        <div class="info-card">
          <div class="info-flex">
            <div class="info-visual">🌻</div>
            <div class="info-text">
              <h3>Reproducción en plantas</h3>
              <p>Las plantas también tienen distintas formas de reproducirse:</p>
              <div class="badge-row">
                <div class="badge"><span class="dot" style="background:var(--orange)"></span>🌰 Semillas: tras la polinización de la flor</div>
                <div class="badge"><span class="dot" style="background:var(--green)"></span>🌿 Esporas: en helechos y musgos</div>
                <div class="badge"><span class="dot" style="background:var(--blue)"></span>🥔 Vegetativa: de tallos, raíces u hojas (papa, fresa)</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Estrategias -->
      <h3 style="margin-top:44px;">🧩 Estrategias de enseñanza inclusiva</h3>
      <div class="strat-grid">
        <div class="strat-card"><div class="se">🖼️</div><div><h4>Organizadores visuales</h4><p>Esquemas, íconos y colores en vez de resúmenes largos.</p></div></div>
        <div class="strat-card"><div class="se">👆</div><div><h4>Actividades táctiles</h4><p>Clasificar tocando tarjetas, sin exigir escritura manual.</p></div></div>
        <div class="strat-card"><div class="se">🎧</div><div><h4>Apoyo audiovisual</h4><p>Videos cortos e imágenes que refuerzan cada tema.</p></div></div>
        <div class="strat-card"><div class="se">✅</div><div><h4>Evaluación oral y de opción múltiple</h4><p>Se prioriza hablar y seleccionar sobre escribir extenso.</p></div></div>
        <div class="strat-card"><div class="se">🤝</div><div><h4>Trabajo en pareja o grupo</h4><p>Aprendizaje colaborativo con apoyo entre compañeros.</p></div></div>
        <div class="strat-card"><div class="se">⏱️</div><div><h4>Tiempo flexible</h4><p>Ritmo adaptado y uso de tablet o computador si se necesita.</p></div></div>
      </div>
      <div class="callout">
        💜 <b>Inclusión en acción:</b> todas las actividades de esta unidad se resuelven tocando, seleccionando o hablando — pensadas para que un estudiante con disgrafia participe con total confianza.
      </div>
    </div>
  </section>

  <!-- ===== ACTIVIDADES ===== -->
  <section id="actividades" style="background:#fff;">
    <div class="wrap">
      <div class="section-title">
        <span class="tag" style="background:var(--orange)">A jugar y aprender</span>
        <h2>Actividades interactivas</h2>
      </div>
      <p class="section-intro">Toca la tarjeta y luego toca la categoría correcta. ¡No necesitas escribir nada!</p>

      <!-- Actividad 1: Animales -->
      <div class="activity-card">
        <div class="activity-head"><span class="aemoji">🐾</span><h3>Clasifica los animales</h3></div>
        <div class="activity-instructions">👉 Toca un animal y después toca su categoría: Ovíparo, Vivíparo u Ovovivíparo.</div>
        <div class="game-area">
          <div class="cards-pool" id="poolAnimales"></div>
          <div class="buckets" id="bucketsAnimales">
            <div class="bucket" data-cat="oviparo" style="--b-color:var(--red)"><h5>🥚 Ovíparo</h5></div>
            <div class="bucket" data-cat="viviparo" style="--b-color:var(--green)"><h5>🐣 Vivíparo</h5></div>
            <div class="bucket" data-cat="ovoviviparo" style="--b-color:var(--purple)"><h5>🐍 Ovovivíparo</h5></div>
          </div>
        </div>
        <button class="check-btn" onclick="checkGame('animales')">Revisar</button>
        <button class="reset-btn" onclick="resetGame('animales')">Reiniciar</button>
        <div class="feedback-msg" id="feedbackAnimales"></div>
      </div>

      <!-- Actividad 2: Plantas -->
      <div class="activity-card">
        <div class="activity-head"><span class="aemoji">🌿</span><h3>Clasifica las plantas</h3></div>
        <div class="activity-instructions">👉 Toca una planta y después toca su tipo de reproducción.</div>
        <div class="game-area">
          <div class="cards-pool" id="poolPlantas"></div>
          <div class="buckets" id="bucketsPlantas">
            <div class="bucket" data-cat="semilla" style="--b-color:var(--orange)"><h5>🌰 Semillas</h5></div>
            <div class="bucket" data-cat="espora" style="--b-color:var(--green)"><h5>🌿 Esporas</h5></div>
            <div class="bucket" data-cat="vegetativa" style="--b-color:var(--blue)"><h5>🥔 Vegetativa</h5></div>
          </div>
        </div>
        <button class="check-btn" onclick="checkGame('plantas')">Revisar</button>
        <button class="reset-btn" onclick="resetGame('plantas')">Reiniciar</button>
        <div class="feedback-msg" id="feedbackPlantas"></div>
      </div>
    </div>
  </section>

  <!-- ===== QUIZ ===== -->
  <section id="quiz">
    <div class="wrap">
      <div class="section-title">
        <span class="tag" style="background:var(--navy)">Ponte a prueba</span>
        <h2>Quiz de selección múltiple</h2>
      </div>
      <p class="section-intro">Toca la respuesta correcta. Recibirás la corrección al instante.</p>
      <div class="activity-card" id="quizContainer"></div>
    </div>
  </section>

</main>

<footer>
  <p><b>INEDEP</b> · Institución Educativa para la Educación, Diversidad y Progreso</p>
  <p>Biología · Unidad 1 · Reproducción en animales y plantas</p>
</footer>

<script>
  // ----- Tabs de contenido -----
  document.querySelectorAll('.ctab').forEach(tab=>{
    tab.addEventListener('click', ()=>{
      document.querySelectorAll('.ctab').forEach(t=>t.classList.remove('active'));
      document.querySelectorAll('.content-panel').forEach(p=>p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.dataset.tab).classList.add('active');
    });
  });

  // ----- Juegos de clasificación (tap-select, tap-target) -----
  const gamesData = {
    animales: {
      pool: 'poolAnimales', buckets: 'bucketsAnimales', feedback: 'feedbackAnimales',
      items: [
        {emoji:'🐔', label:'Gallina', cat:'oviparo'},
        {emoji:'🐶', label:'Perro', cat:'viviparo'},
        {emoji:'🦈', label:'Tiburón', cat:'ovoviviparo'},
        {emoji:'🐟', label:'Pez', cat:'oviparo'},
        {emoji:'🐄', label:'Vaca', cat:'viviparo'},
        {emoji:'🐍', label:'Víbora', cat:'ovoviviparo'},
      ]
    },
    plantas: {
      pool: 'poolPlantas', buckets: 'bucketsPlantas', feedback: 'feedbackPlantas',
      items: [
        {emoji:'🌻', label:'Girasol', cat:'semilla'},
        {emoji:'🌾', label:'Trigo', cat:'semilla'},
        {emoji:'🌿', label:'Helecho', cat:'espora'},
        {emoji:'🍄', label:'Musgo', cat:'espora'},
        {emoji:'🥔', label:'Papa', cat:'vegetativa'},
        {emoji:'🍓', label:'Fresa', cat:'vegetativa'},
      ]
    }
  };

  let selectedCard = {animales:null, plantas:null};
  let placements = {animales:{}, plantas:{}};

  function buildGame(key){
    const g = gamesData[key];
    const pool = document.getElementById(g.pool);
    pool.innerHTML = '';
    // shuffle
    const items = [...g.items].sort(()=>Math.random()-0.5);
    items.forEach((it, idx)=>{
      const card = document.createElement('div');
      card.className = 'draggable';
      card.dataset.idx = idx;
      card.dataset.cat = it.cat;
      card.innerHTML = it.emoji + '<span class="label">'+it.label+'</span>';
      card.addEventListener('click', ()=>selectCard(key, card));
      pool.appendChild(card);
    });
    // bucket click handlers
    document.querySelectorAll('#'+g.buckets+' .bucket').forEach(b=>{
      b.onclick = ()=>placeInBucket(key, b);
    });
    placements[key] = {};
    document.getElementById(g.feedback).textContent = '';
  }

  function selectCard(key, card){
    if(card.classList.contains('placed')) return;
    const pool = document.getElementById(gamesData[key].pool);
    pool.querySelectorAll('.draggable').forEach(c=>c.classList.remove('selected'));
    card.classList.add('selected');
    selectedCard[key] = card;
  }

  function placeInBucket(key, bucket){
    const card = selectedCard[key];
    if(!card) return;
    const item = document.createElement('div');
    item.className = 'placed-item';
    item.textContent = card.innerHTML.match(/^[^<]*/)[0]; // just emoji part
    item.dataset.sourceIdx = card.dataset.idx;
    bucket.appendChild(item);
    card.classList.add('placed');
    placements[key][card.dataset.idx] = {cat: bucket.dataset.cat, correctCat: card.dataset.cat, el:item, bucket:bucket};
    selectedCard[key] = null;
  }

  function checkGame(key){
    const g = gamesData[key];
    const fb = document.getElementById(g.feedback);
    let total = g.items.length;
    let placed = Object.keys(placements[key]).length;
    if(placed < total){
      fb.style.color = 'var(--orange)';
      fb.textContent = '🕓 Te faltan '+(total-placed)+' tarjeta(s) por ubicar.';
      return;
    }
    let correct = 0;
    document.querySelectorAll('#'+g.buckets+' .bucket').forEach(b=>b.classList.remove('correct-flash','wrong-flash'));
    Object.values(placements[key]).forEach(p=>{
      if(p.cat === p.correctCat){ correct++; p.bucket.classList.add('correct-flash'); }
      else { p.bucket.classList.add('wrong-flash'); }
    });
    if(correct === total){
      fb.style.color = 'var(--leaf)';
      fb.textContent = '🎉 ¡Excelente! '+correct+'/'+total+' correctas.';
    } else {
      fb.style.color = 'var(--red)';
      fb.textContent = '💪 Tienes '+correct+'/'+total+' correctas. ¡Sigue intentando!';
    }
  }

  function resetGame(key){
    buildGame(key);
  }

  buildGame('animales');
  buildGame('plantas');

  // ----- QUIZ -----
  const quizData = [
    {
      q:'¿Qué tipo de reproducción necesita dos padres y produce mayor diversidad?',
      opts:['Reproducción asexual','Reproducción sexual','Reproducción vegetativa','Esporulación'],
      correct:1,
      explain:'La reproducción sexual combina material genético de dos padres, generando diversidad.'
    },
    {
      q:'Un animal que nace de un huevo puesto fuera del cuerpo de la madre es:',
      opts:['Vivíparo','Ovovivíparo','Ovíparo','Asexual'],
      correct:2,
      explain:'Los ovíparos, como las aves y muchos peces, nacen de huevos externos.'
    },
    {
      q:'La papa y la fresa se reproducen principalmente por:',
      opts:['Semillas','Esporas','Reproducción vegetativa','Ovoviviparidad'],
      correct:2,
      explain:'Se reproducen a partir de tallos o raíces: reproducción vegetativa.'
    },
    {
      q:'Los helechos y musgos se reproducen por medio de:',
      opts:['Esporas','Flores','Vivíparidad','Huevos'],
      correct:0,
      explain:'Los helechos y musgos usan esporas en lugar de semillas.'
    },
    {
      q:'Una víbora cuyo huevo se desarrolla dentro de su cuerpo y nace vivo es un ejemplo de:',
      opts:['Vivíparo','Ovíparo','Ovovivíparo','Reproducción asexual'],
      correct:2,
      explain:'Es ovovivíparo: el huevo se desarrolla dentro de la madre y nace vivo.'
    }
  ];

  const quizContainer = document.getElementById('quizContainer');
  let score = 0;
  let answered = 0;

  quizData.forEach((item, qi)=>{
    const qDiv = document.createElement('div');
    qDiv.className = 'quiz-q';
    const qText = document.createElement('p');
    qText.className = 'qtext';
    qText.textContent = (qi+1)+'. '+item.q;
    qDiv.appendChild(qText);
    const optsDiv = document.createElement('div');
    optsDiv.className = 'quiz-opts';
    const explain = document.createElement('p');
    explain.className = 'quiz-explain';
    explain.textContent = '💡 ' + item.explain;

    item.opts.forEach((opt, oi)=>{
      const btn = document.createElement('button');
      btn.className = 'opt-btn';
      btn.textContent = opt;
      btn.addEventListener('click', ()=>{
        if(btn.disabled) return;
        const allBtns = optsDiv.querySelectorAll('.opt-btn');
        allBtns.forEach(b=>b.disabled = true);
        if(oi === item.correct){
          btn.classList.add('correct');
          score++;
        } else {
          btn.classList.add('wrong');
          allBtns[item.correct].classList.add('correct');
        }
        explain.style.display = 'block';
        answered++;
        if(answered === quizData.length){
          const scoreDiv = document.createElement('div');
          scoreDiv.className = 'quiz-score';
          scoreDiv.textContent = '🏆 Puntaje final: '+score+' / '+quizData.length;
          quizContainer.appendChild(scoreDiv);
        }
      });
      optsDiv.appendChild(btn);
    });
    qDiv.appendChild(optsDiv);
    qDiv.appendChild(explain);
    quizContainer.appendChild(qDiv);
  });
</script>
</body>
</html>
